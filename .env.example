# Weave 开发环境配置示例
# 复制此文件为 .env 并根据您的环境修改配置

# Obsidian 仓库路径 (必需)
# 指向您的 Obsidian 仓库的 .obsidian 目录
# 例如: OBSIDIAN_VAULT_PATH="C:/Users/you/my-vault/.obsidian"
OBSIDIAN_VAULT_PATH=""
# 桌面热重载同步到的插件目录名（位于 plugins/ 下）
# 例如: OBSIDIAN_PLUGIN_ID=weave-epub-reader
OBSIDIAN_PLUGIN_ID=weave-epub-reader

# 开发模式配置
NODE_ENV=development

# 构建配置
VITE_BUILD_TARGET=development
VITE_SOURCEMAP=true
VITE_MINIFY=false

# 热重载配置
VITE_HMR=true
VITE_WATCH_POLLING=true
VITE_WATCH_INTERVAL=300

# Android ADB 热重载配置
# 可选：adb 可执行文件路径；留空时优先使用仓库内 platform-tools/adb.exe，否则回退到系统 PATH 中的 adb
WEAVE_MOBILE_ADB_PATH=""
# 可选：多设备时指定 adb serial，例如 emulator-5554
WEAVE_MOBILE_ADB_SERIAL=""
# 可选：mobile 热重载临时输出目录
WEAVE_MOBILE_SOURCE_DIR=""
# 推荐：直接填写手机上的插件目录
# 例如：/storage/emulated/0/Documents/obsidian luman/.obsidian/plugins/weave-epub-reader
WEAVE_MOBILE_PLUGIN_DIR=""
# 也可以只填写 Vault 根目录，脚本会自动拼接 /.obsidian/plugins/weave-epub-reader
# 例如：/storage/emulated/0/Documents/obsidian luman
WEAVE_MOBILE_VAULT_ROOT=""

# 调试配置
DEBUG_MODE=true
VERBOSE_LOGGING=false
PERFORMANCE_MONITORING=false

# 插件配置
PLUGIN_ID=weave
PLUGIN_NAME="Weave"
PLUGIN_VERSION=0.7.8

# 测试配置
VITEST_ENVIRONMENT=jsdom
VITEST_COVERAGE=true
