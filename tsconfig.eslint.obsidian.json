{
	"extends": "./tsconfig.json",
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts",
		"src/**/*.svelte"
	],
	"exclude": [
		"dist/**",
		"backup-before-migration/**",
		"src/demo/**",
		"src/tests/**",
		"src/test-integration.ts",
		"src/**/*.test.ts",
		"src/**/*.spec.ts",
		"src/**/__tests__/**"
	]
}
